{
  "manifest_version": 3,
  "name": "AI Browser Guard",
  "version": "1.0.0",
  "description": "🚀 100% Automatic ad removal, harmful link blocking, smart organization & exclusive tab privacy",
  "author": "Hackathon Team",
  
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "notifications",
    "cookies",
    "scripting"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "🎯 AI Browser Guard Dashboard",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  
  "options_page": "options.html",
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
