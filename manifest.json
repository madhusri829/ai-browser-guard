{
  "manifest_version": 3,
  "name": "AI Browser Guard - AdBlock + Privacy",
  "version": "1.0.0",
  "description": "AI-powered ad blocker, content organizer, privacy guard with smart reminders",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "notifications",
    "webNavigation",
    "webRequest",
    "webRequestBlocking",
    "cookies"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Browser Guard"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
